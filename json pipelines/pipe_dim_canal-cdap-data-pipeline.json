{
    "name": "pipe_dim_canal",
    "description": "Data Pipeline Application",
    "artifact": {
        "name": "cdap-data-pipeline",
        "version": "6.11.1",
        "scope": "SYSTEM"
    },
    "config": {
        "resources": {
            "memoryMB": 2048,
            "virtualCores": 1
        },
        "driverResources": {
            "memoryMB": 2048,
            "virtualCores": 1
        },
        "connections": [
            {
                "from": "GCSFile",
                "to": "Wrangler"
            },
            {
                "from": "Wrangler",
                "to": "BigQuery"
            }
        ],
        "postActions": [],
        "properties": {},
        "processTimingEnabled": true,
        "stageLoggingEnabled": true,
        "stages": [
            {
                "name": "GCSFile",
                "plugin": {
                    "name": "GCSFile",
                    "type": "batchsource",
                    "label": "GCSFile",
                    "artifact": {
                        "name": "google-cloud",
                        "version": "0.24.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "copyHeader": "true",
                        "path": "gs://supermercado_grupo1/tb_canal_venta.csv",
                        "fileEncoding": "UTF-8",
                        "useConnection": "true",
                        "format": "csv",
                        "enableQuotedValues": "false",
                        "connection": "${conn(Cloud Storage Default)}",
                        "skipHeader": "true",
                        "referenceName": "scr_dim_canalVenta",
                        "schema": "{\"type\":\"record\",\"name\":\"text\",\"fields\":[{\"name\":\"id_canal\",\"type\":\"int\"},{\"name\":\"tipo_canal\",\"type\":\"string\"}]}",
                        "sampleSize": "1000",
                        "filenameOnly": "false",
                        "recursive": "false",
                        "ignoreNonExistingFolders": "false",
                        "encrypted": "false"
                    }
                },
                "outputSchema": "{\"type\":\"record\",\"name\":\"text\",\"fields\":[{\"name\":\"id_canal\",\"type\":\"int\"},{\"name\":\"tipo_canal\",\"type\":\"string\"}]}",
                "id": "GCSFile",
                "type": "batchsource",
                "label": "GCSFile",
                "icon": "fa-plug",
                "$$hashKey": "object:32",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "560px",
                    "top": "356.5px"
                }
            },
            {
                "name": "Wrangler",
                "plugin": {
                    "name": "Wrangler",
                    "type": "transform",
                    "label": "Wrangler",
                    "artifact": {
                        "name": "wrangler-transform",
                        "version": "4.11.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "directives": "parse-as-csv :body ',' true\nrename :id_canal :id_canal_nk\ncopy :id_canal_nk :id_canal_sk\nset-type :id_canal_sk long\nset-type :id_canal_nk long\ntrim :tipo_canal",
                        "field": "*",
                        "precondition": "false",
                        "workspaceId": "55380049-9e3f-4c4c-b559-6eee52cdee66",
                        "schema": "{\"type\":\"record\",\"name\":\"output\",\"fields\":[{\"name\":\"id_canal_nk\",\"type\":[\"long\",\"null\"]},{\"name\":\"tipo_canal\",\"type\":[\"string\",\"null\"]},{\"name\":\"id_canal_sk\",\"type\":[\"long\",\"null\"]}]}"
                    }
                },
                "outputSchema": [
                    {
                        "name": "etlSchemaBody",
                        "schema": "{\"type\":\"record\",\"name\":\"output\",\"fields\":[{\"name\":\"id_canal_nk\",\"type\":[\"long\",\"null\"]},{\"name\":\"tipo_canal\",\"type\":[\"string\",\"null\"]},{\"name\":\"id_canal_sk\",\"type\":[\"long\",\"null\"]}]}"
                    }
                ],
                "id": "Wrangler",
                "type": "transform",
                "label": "Wrangler",
                "icon": "icon-DataPreparation",
                "$$hashKey": "object:33",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "860px",
                    "top": "356.5px"
                }
            },
            {
                "name": "BigQuery",
                "plugin": {
                    "name": "BigQueryTable",
                    "type": "batchsink",
                    "label": "BigQuery",
                    "artifact": {
                        "name": "google-cloud",
                        "version": "0.24.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "useConnection": "true",
                        "connection": "${conn(BigQuery Default)}",
                        "referenceName": "sink_dim_canal",
                        "dataset": "dw_supermercado",
                        "table": "dim_canal",
                        "operation": "insert",
                        "truncateTable": "true",
                        "allowSchemaRelaxation": "false",
                        "readTimeout": "120",
                        "location": "US",
                        "createPartitionedTable": "false",
                        "partitioningType": "TIME",
                        "timePartitioningType": "DAY",
                        "partitionFilterRequired": "false",
                        "schema": "{\"type\":\"record\",\"name\":\"output\",\"fields\":[{\"name\":\"id_canal_sk\",\"type\":\"long\"},{\"name\":\"id_canal_nk\",\"type\":\"long\"},{\"name\":\"tipo_canal\",\"type\":\"string\"}]}"
                    }
                },
                "outputSchema": [
                    {
                        "name": "etlSchemaBody",
                        "schema": "{\"type\":\"record\",\"name\":\"output\",\"fields\":[{\"name\":\"id_canal_sk\",\"type\":\"long\"},{\"name\":\"id_canal_nk\",\"type\":\"long\"},{\"name\":\"tipo_canal\",\"type\":\"string\"}]}"
                    }
                ],
                "inputSchema": [
                    {
                        "name": "Wrangler",
                        "schema": "{\"type\":\"record\",\"name\":\"output\",\"fields\":[{\"name\":\"id_canal_nk\",\"type\":[\"long\",\"null\"]},{\"name\":\"tipo_canal\",\"type\":[\"string\",\"null\"]},{\"name\":\"id_canal_sk\",\"type\":[\"long\",\"null\"]}]}"
                    }
                ],
                "id": "BigQuery",
                "type": "batchsink",
                "label": "BigQuery",
                "icon": "fa-plug",
                "$$hashKey": "object:34",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "1160px",
                    "top": "356.5px"
                }
            }
        ],
        "schedule": "0 1 */1 * *",
        "engine": "spark",
        "numOfRecordsPreview": 100,
        "rangeRecordsPreview": {
            "min": 1,
            "max": "5000"
        },
        "maxConcurrentRuns": 1,
        "pushdownEnabled": false,
        "transformationPushdown": {}
    },
    "version": "86776073-3c1b-11f1-a276-e68fa79946d5"
}